{
    "version": 2,
    "settings": { 
        "appearanceTools": true,
        "border": {
            "defaultColor": "var(--wp--preset--color--u-gray-300)",
            "defaultWidth": "1px",
            "defaultStyle": "solid",
            "color": true,
            "width": true,
            "style": true
        },
        "color": {
            "defaultPalette": false,
            "palette":[
                { "slug": "u-white", "color": "rgb(255 255 255)", "name": "Udemy White" },
                { "slug": "u-gray-100", "color": "rgb(243 244 246)", "name": "Udemy Gray 100" },
                { "slug": "u-gray-200", "color": "rgb(229 231 235)", "name": "Udemy Gray 200" },
                { "slug": "u-gray-300", "color": "rgb(209 213 219)", "name": "Udemy Gray 300" },
                { "slug": "u-gray-400", "color": "rgb(156 163 175)", "name": "Udemy Gray 400" },
                { "slug": "u-gray-500", "color": "rgb(107 114 128)", "name": "Udemy Gray 500" },
                { "slug": "u-gray-600", "color": "rgb(75 85 99)", "name": "Udemy Gray 600" },
                { "slug": "u-gray-700", "color": "rgb(55 65 81)", "name": "Udemy Gray 700" },
                { "slug": "u-gray-800", "color": "rgb(31 41 55)", "name": "Udemy Gray 800" },
                { "slug": "u-gray-900", "color": "rgb(17 24 39)", "name": "Udemy Gray 900" },
                { "slug": "u-primary", "color": "rgb(239 68 68)", "name": "Udemy Primary" },
                { "slug": "u-accent", "color": "rgb(67 56 202)", "name": "Udemy Accent" },
                { "slug": "u-success", "color": "rgb(52 211 153)", "name": "Udemy Success" },
                { "slug": "u-info", "color": "rgb(96 165 250)", "name": "Udemy Info" },
                { "slug": "u-warning", "color": "rgb(251 146 60)", "name": "Udemy Warning" },
                { "slug": "u-danger", "color": "rgb(236 72 153)", "name": "Udemy Danger" }
            ],
            "background": true,
            "text": true,
            "link": true,
            "duotone": [
                {
                    "name": "Udemy Pink Sunset",
                    "slug": "u-pink-sunset",
                    "colors": ["#11245e", "#dc4379"]
                }
            ],
            "defaultGradients": false,
            "gradients": [
                {
                    "name": "Summer Dog",
                    "slug": "summer-dog",
                    "gradient": "linear-gradient(135deg, #a8ff78 0%, #78ffd6 100%)"
                }
            ]
        },
        "blocks":{
            
            "core/site-title": {
                "color": {
                    "defaultPalette": true,
                    "palette":[
                        { "slug": "u-primary", "color": "#ef4444", "name": "Udemy Primary" },
                        { "slug": "u-accent", "color": "#4338ca", "name": "Udemy Accent" },
                        { "slug": "u-success", "color": "#34d399", "name": "Udemy Success" },
                        { "slug": "u-info", "color": "#60a5fa", "name": "Udemy Info" },
                        { "slug": "u-warning", "color": "#fb923c", "name": "Udemy Warning" },
                        { "slug": "u-danger", "color": "#ec4899", "name": "Udemy Danger" }
                     ],
                     "link": true
                },
                "typography": {
                    "fontFamilies": [
                        {
                            "name": "U Pacifico",
                            "slug": "u-pacifico",
                            "fontFamily": "Pacifico, sans-serif"
                        }
                    ],
                    "fontSize": true
                 }
            },
            "core/preformatted": {
                "typography": {
                    "fontSize": [],
                    "customFontSize": false
                 }
            }
        },
        "typography": {      
            "fontFamilies": [
                {
                    "name": "U Rubik",
                    "slug": "u-rubik",
                    "fontFamily": "Rubik, sans-serif"
                }
            ],
            "fontSizes": [
                {"slug": "default", "size": "1rem", "name": "Default"},
                {"slug": "small", "size": "0.75rem", "name": "Small"},
                {"slug": "medium", "size": "1.25rem", "name": "Medium"},
                {"slug": "large", "size": "2.5rem", "name": "Large"},
                {"slug": "x-large", "size": "3rem", "name": "X-Large"},
                {"slug": "gigantic", "size": "3.75rem", "name": "Gigantic"}
             ],
             "lineHeight": true,
             "dropCap": true,
             "fontWeight": true,
             "fontStyle": true,
             "textTransform": true,
             "letterSpacing": true,
             "textDecoration": true
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "units": ["px", "vw", "vh", "rem", "%"],
                "blockGap": "true",
                "blockGapCustomProperty": "gap"
        }
    },
    "styles": {

        "color": {
            "background": "var(--wp--preset--color--u-gray-100)",
            "text": "var(--wp--preset--color--u-gray-700)",
            "link": "var(--wp--preset--color--u-primary)"
        },
        "typography": {
            "fontSize": "16px",
            "fontFamily": "var(--wp--preset--font-family--u-rubik)",
            "fontStyle": "normal",
            "fontWeight": "normal",
            "lineHeight": "inherit",
            "textTransform": "none",
            "letterSpacing": "normal",
            "textDecoration": "none"
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)"
                },
                "link":{
                    "text": "var(--wp--preset--color--u-primary)"
                }
            }
        },
        "blocks": {
            "core/button": {
               
            },
            "core/pullquote": {
                "border": {
                    "radius": "10px",
                    "width": "2px",
                    "style": "solid",
                    "color": "var(--wp--preset--color--u-primary)"
                }
            },
            "core/site-title": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--u-pacifico)"
                }
            }
        },
        "spacing": {
            "margin": {
                "top": "0",
                "bottom": "0",
                "left": "0",
                "right": "0"
             },
            "padding": {
                "top": "0",
                "bottom": "0",
                "left": "0",
                "right": "0"
            },
             "blockGap": "3rem"
         }
    }, 
    "customTemplates": [
        {
            "name": "full-width-page",
            "title": "Full Width Page",
            "description": "A custom template for full width pages.",
            "postTypes": ["page"],
            "template": [
                ["core/paragraph", {"placeholder": "Enter your content here..."}],
                ["core/image", {}],
                ["core/paragraph", {"placeholder": "Add more content here..."}]
            ]
        }
    ]
}