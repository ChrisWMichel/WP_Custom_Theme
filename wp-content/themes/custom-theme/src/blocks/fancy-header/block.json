
{
    "name": "custom-plus/fancy-header",
    "apiVersion": 3,
    "version": "1.0.0",
    "title": "Fancy Header",
    "category": "text",
    "icon": "star-filled",
    "description": "A block that underlines a heading when hovered.",
    "keywords": [
        "hover",
        "header",
        "underline"
    ],
    "textdomain": "custom-plus",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./index.css",
    "attributes": {
        "content": {
            "type": "string",
            "source": "html",
            "selector": "h2"
        },
        "underline_color": {
            "type": "string",
            "default": "#f87171"
        }
    }
}